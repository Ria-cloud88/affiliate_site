---
import { SITE_TITLE } from '../consts';
---

<header>
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-main">AIツール・副業</span>
      <span class="logo-sub">完全ガイド</span>
    </a>
    <nav>
      <a href="/">ホーム</a>
      <a href="/blog">ブログ一覧</a>
      <a href="/blog?genre=AIツール">AIツール</a>
      <a href="/blog?genre=副業">副業</a>
    </nav>
  </div>
</header>

<style>
  header {
    background: white;
    border-bottom: 3px solid #1a2b5f;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    position: sticky;
    top: 0;
    z-index: 200;
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    line-height: 1.2;
  }

  .logo-main {
    font-size: 1.1em;
    font-weight: 900;
    color: #1a2b5f;
    letter-spacing: -0.5px;
  }

  .logo-sub {
    font-size: 0.7em;
    color: #1a56db;
    font-weight: bold;
  }

  nav {
    display: flex;
    gap: 4px;
  }

  nav a {
    padding: 6px 12px;
    color: #333;
    font-size: 0.85em;
    text-decoration: none;
    border-radius: 4px;
    transition: background 0.15s;
  }

  nav a:hover {
    background: #f0f4ff;
    color: #1a56db;
    text-decoration: none;
  }

  @media (max-width: 600px) {
    nav a:not(:first-child) { display: none; }
  }
</style>
